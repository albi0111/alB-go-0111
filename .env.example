# ──────────────────────────────────────────────────────────────────────────────
# Nifty Options Algo Trader — Environment Configuration Template
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Upstox API Credentials ────────────────────────────────────────────────────
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here

# Static token for market data (read-only; doesn't expire daily)
UPSTOX_ANALYSIS_TOKEN=your_analysis_token_here

# Daily token for order placement (updated each morning via: algo --uptrade)
# This is prompted at startup in --uptrade mode; leave blank to always prompt.
UPSTOX_TRADING_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default):
DB_URL=sqlite:///database/algo.db
# PostgreSQL (optional override):
# DB_URL=postgresql://user:password@localhost:5432/algo_db

# ── Position & Risk Limits ────────────────────────────────────────────────────
LOT_SIZE=65           # Nifty options: 1 lot = 65 qty
MAX_LOTS=2            # Maximum lots per trade (1 or 2)
MAX_OPEN_POSITIONS=1  # Enforce single-trade concurrency
DAILY_LOSS_LIMIT=5000 # Stop trading after this INR loss in a day

# ── Strategy Tolerances ───────────────────────────────────────────────────────
# These make the strategy adaptive — not rigidly strict.
# Increase to be more permissive; decrease to be more selective.

VOLUME_SPIKE_RATIO=1.5        # Volume > ratio × 20-candle avg → spike
VWAP_PROXIMITY_PCT=0.003      # Within 0.3% of VWAP counts as "near"
BREAKOUT_MARGIN_PCT=0.002     # Price within 0.2% of breakout level
EMA_DIFF_TOLERANCE=0.0        # Allow EMA20 ≈ EMA50 within this fraction
SIGNAL_STRENGTH_THRESHOLD=0.6 # Trade only if composite score ≥ this (0–1)

# ── AI Filter ─────────────────────────────────────────────────────────────────
AI_CONFIDENCE_THRESHOLD=0.6   # Min probability from model to allow trade
AI_MIN_SAMPLES=50             # Skip AI filter if dataset is too small

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO     # DEBUG | INFO | WARNING | ERROR
